{
  "name": "mern-hello-docker-monorepo",
  "version": "1.0.0",
  "description": "Monorepo orchestration wrapper for Project Hello-Docker",
  "type": "module",
  "scripts": {
    "install-all": "concurrently \"npm install --prefix frontend\" \"npm install --prefix backend\"",
    "backend": "npm run dev --prefix backend",
    "frontend": "npm run dev --prefix frontend",
    "dev": "concurrently --kill-others-on-fail \"npm run backend\" \"npm run frontend\""
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}